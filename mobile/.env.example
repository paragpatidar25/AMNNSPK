# GOE Mobile — Environment Variables
# Copy to .env and fill in your values

# Backend API base URL (no trailing slash)
# For local dev with Expo Go on physical device, use your machine's LAN IP
EXPO_PUBLIC_API_URL=http://localhost:5000

# For Android emulator pointing to host machine:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000

# For production (ASP.NET Core API):
# EXPO_PUBLIC_API_URL=https://api.goe.example.com
